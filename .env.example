# ─────────────────────────────────────────────
#  Facebook Groups Post Bot — Environment File
# ─────────────────────────────────────────────

# Path to your Chrome user-data directory
# Windows example: C:\Users\YourName\AppData\Local\Google\Chrome\User Data
CHROME_FOLDER=

# Chrome profile name (usually "Default")
PROFILE=Default

# Minutes to wait between posting in each group (min bound)
WAIT_MIN=2

# Folder where error screenshots are saved
SCREENSHOT_DIR=screenshots

# Folder where log files are saved
LOG_DIR=logs
